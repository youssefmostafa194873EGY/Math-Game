#include <iostream>
using namespace std;

enum enchoose { right = 1,wrong = 2 };
enum entype {add = 1,sub=2,mul=3,divid=4,mix=5};


struct stgameresult {
	short gamerounds = 0;
	short level = 0;
	short rightanwser = 0;
	short wronganwser = 0;
	short numbertype = 0;
	short sum = 0;
	short anwser = 0;
	entype type = add;
	
};


struct stnumbers {
	short number1=0;
	short number2=0;
};

short checkpositive(string massage) {
	short number = 0;
	do {
		cout << massage;
		cin >> number;

	} while (number <= 0);
	return number;
}

short randomnumber(short from, short to) {
	short randnum = rand() % (to - from + 1) + from;
	return randnum;
}

short checklevel(string massage) {
	short number = 0;
	do {
		cout << massage;
		cin >> number;

	} while (number < 0||number > 4);
	return number;
}

short checktype(string massage) {
	short number = 0;
	do {
		cout << massage;
		cin >> number;

	} while (number < 0 || number > 5);
	return number;
}

stgameresult sumofnumber(stgameresult gameresult,stnumbers numbers) {
	
	if (gameresult.numbertype == 5) {
		gameresult.numbertype = randomnumber(1, 4);
	}

	if (gameresult.numbertype == 1) {
		gameresult.sum = numbers.number1 + numbers.number2;
		gameresult.type = add;
		return gameresult;
	}

	if (gameresult.numbertype == 2) {
		gameresult.sum = numbers.number1 - numbers.number2;
		gameresult.type = sub;
		return gameresult;
	}

	if (gameresult.numbertype == 3) {
		gameresult.sum = numbers.number1 * numbers.number2;
		gameresult.type = mul;
		return gameresult;
	}
	if (gameresult.numbertype == 4) {
		gameresult.sum = numbers.number1 / numbers.number2;
		gameresult.type = divid;
		return gameresult;
	}

}

stnumbers levels(stgameresult gameresult) {
	
	stnumbers number;

	if (gameresult.level == 4) {
		gameresult.level = randomnumber(1, 3);
	}

	if (gameresult.level == 1) {
		number.number1 = randomnumber(1, 10);
		number.number2 = randomnumber(1, 10);
		return number;
	}

	if (gameresult.level == 2) {
		number.number1 = randomnumber(10, 100);
		number.number2 = randomnumber(10, 100);
		return number;
	}

	if (gameresult.level == 3) {
		number.number1 = randomnumber(100, 1000);
		number.number2 = randomnumber(100, 1000);
		return number;
	}

}

char types(stgameresult gameresult) {
	
	if (gameresult.type == add)
		return '+';
	if (gameresult.type == sub)
		return '-';
	if (gameresult.type == mul)
		return '*';
	if (gameresult.type == divid)
		return '/';
}


short question(stgameresult gameresult, stnumbers numbers, short qustions) {
	short anwser = 0;
	cout << "\nqustions [ " << qustions << "/" << gameresult.gamerounds<<" ]:\n\n";
	cout << numbers.number1 << endl;
	cout << numbers.number2 <<" " << types(gameresult) << endl;
	cout <<"----------------------------"<< "\n";
	cin >> anwser;
	
	return anwser;
}

enchoose checkanwser(stgameresult gameresult) {
	if (gameresult.anwser == gameresult.sum) {
		cout << "\n\ngood job , right anwser.\n\n\n";
		system("color 2F");
		return (enchoose)1;
	}
	if (gameresult.anwser != gameresult.sum) {
		cout << "\n\nsorry , wrong anwser.\n\n\n";
		system("color 4F");
		return (enchoose)2;
	}
}

stgameresult addto_r_w(stgameresult gameresult,enchoose choose) {
	if (choose == 1) {
		gameresult.rightanwser++;
		return gameresult;
	}
	if (choose == 2) {
		gameresult.wronganwser++;
		return gameresult;
	}
}

string passornot(stgameresult gameresult){
	if (gameresult.rightanwser >= gameresult.wronganwser)
		return "pass";			  
	if (gameresult.rightanwser < gameresult.wronganwser)
		return "not pass";
}

void finalresult(stgameresult gameresults) {
	
	cout << "----------------------------------------------------\n\n";
	cout << "final result is " << passornot(gameresults)<<"\n\n";
	cout << "----------------------------------------------------\n\n";
	cout << "number of questions : " << gameresults.gamerounds << "\n";
	cout << "questions level : " << gameresults.level << "\n";
	cout << "DPtype : " << types(gameresults) << "\n";
	cout << "number of right answer : " << gameresults.rightanwser << "\n";
	cout << "number of wrong answer : " << gameresults.wronganwser << "\n";
	cout << "----------------------------------------------------\n\n";
}

void startgame(stgameresult gameresult){
	
	short temp = gameresult.numbertype;
	
	for (short qustions = 1; qustions <= gameresult.gamerounds; qustions++) {
		stnumbers numbers = levels(gameresult);
		gameresult = sumofnumber(gameresult,numbers);
		gameresult.anwser = question(gameresult,numbers,qustions);
		enchoose choose = checkanwser(gameresult);
		gameresult = addto_r_w(gameresult,choose);
		

		gameresult.numbertype = temp;
		
	}
		finalresult(gameresult);

}

void resetscreen() {
	system("cls");
	system("color 0F");
}

void project() {
	char anwser ='y';
	do{

	resetscreen();
	stgameresult gameresult;
	gameresult.gamerounds = checkpositive("how many questions do you want to anwser ? \n");
	gameresult.level = checklevel("\nenter operations level [1] easy , [2] med ,[3] hard ,[4] mix ? \n");
	gameresult.numbertype = checktype("\nenter operations [1]add , [2] sub , [3] mul , [4] div ,[5] mix \n");
	startgame(gameresult);
	cout << "do you want play again (y/n):";
	cin >> anwser;

	} while (anwser == 'y'|| anwser == 'Y');

}


int main(void) {
	srand((unsigned)time(NULL));
	project();

}
